{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "jsx": "preserve",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"],
      "@forge/db": ["../../packages/db/src"],
      "@forge/shared": ["../../packages/shared/src"],
      "@forge/auth": ["../../packages/auth/src"],
      "@forge/logger": ["../../packages/logger/src"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
