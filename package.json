{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "description": "FORGE — Framework for Organisational Resource Governance and Efficiency",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "db:migrate": "pnpm --filter @forge/db prisma migrate dev",
    "db:seed": "pnpm --filter @forge/db prisma db seed",
    "db:studio": "pnpm --filter @forge/db prisma studio",
    "db:generate": "pnpm --filter @forge/db prisma generate",
    "test:e2e": "playwright test",
    "clean": "turbo clean && rimraf node_modules"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "turbo": "^2.8.10",
    "typescript": "^5.6.0"
  }
}
