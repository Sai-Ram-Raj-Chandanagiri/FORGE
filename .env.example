# ===========================================
# FORGE Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values

# Database
DATABASE_URL="postgresql://forge:forge_dev_password@localhost:5432/forge"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="" # Generate with: openssl rand -base64 32

# OAuth Providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Redis
REDIS_URL="redis://localhost:6379"

# File Storage
STORAGE_TYPE="local" # "local" | "s3"
STORAGE_LOCAL_PATH="./uploads"
# S3_BUCKET=""
# S3_REGION=""
# S3_ACCESS_KEY=""
# S3_SECRET_KEY=""

# Docker
DOCKER_SOCKET_PATH="/var/run/docker.sock"
DOCKER_NETWORK_PREFIX="forge-user-"
CONTAINER_PORT_RANGE_START=10000
CONTAINER_PORT_RANGE_END=20000

# Stripe (Phase 6)
# STRIPE_SECRET_KEY=""
# STRIPE_WEBHOOK_SECRET=""
# STRIPE_PUBLISHABLE_KEY=""

# Email (Phase 7)
# SMTP_HOST=""
# SMTP_PORT=""
# SMTP_USER=""
# SMTP_PASSWORD=""
# EMAIL_FROM="noreply@forge.dev"

# Google AI (Phase 5)
# GOOGLE_AI_API_KEY="" # Gemini 2.0 Flash
# GOOGLE_ADK_PROJECT_ID=""

# Logging
LOG_LEVEL="info"
NODE_ENV="development"
